---
import experience from "../content/experience.json";
import logosRaw from "../content/logos.json";
import { useT, pick, type Locale } from "../i18n/ui";
const locale = (Astro.currentLocale ?? "en") as Locale;
const t = useT(locale);
const logos = logosRaw as Record<string, string[]>;
const cols = (key: string) => Math.max(...logos[key].map((l) => l.length));

const VISIBLE = 5;
const rest = experience.slice(VISIBLE);
const restYears = rest.flatMap((e) => (e.period.en.match(/\d{4}/g) ?? []).map(Number));
const extraYears = restYears.length ? Math.max(...restYears) - Math.min(...restYears) || 1 : 0;
const moreLabel = t("exp.more").replace("{y}", String(extraYears));
---
<section class="container exp" aria-labelledby="exp-h">
  <div class="exp__head">
    <h2 id="exp-h">{t("exp.heading")}</h2>
    <span class="exp__info" tabindex="0" role="note" aria-label={t("exp.tooltip-label")}>
      <span class="exp__i" aria-hidden="true">&#9432;</span>
      <span class="exp__tip" role="tooltip">{t("exp.tooltip")}</span>
    </span>
  </div>
  <ol class="exp__log">
    {experience.map((e, i) => (
      <li class="exp__entry" data-reveal hidden={i >= VISIBLE} style={`--i:${i}`}>
        <details class="exp__item">
          <summary>
            <span class="exp__node" aria-hidden="true">{i === 0 ? "●" : "○"}</span>
            <span class="exp__markbox" style={`--cols:${cols(e.logo)}`} aria-hidden="true">
              <pre class="exp__mark">{logos[e.logo].join("\n")}</pre>
            </span>
            <span class="exp__meta">
              <span class="exp__co">{e.company}</span>
              <span class="exp__period">{pick(e.period, locale)} · {pick(e.location, locale)}</span>
              <span class="exp__lead">{e.roles[0].title}</span>
              <span class="exp__toggle"><span class="exp__sign" aria-hidden="true"></span>{e.roles.length} {e.roles.length === 1 ? t("exp.role") : t("exp.roles")}</span>
            </span>
          </summary>
          <ol class="exp__roles">
            {e.roles.map((r, j) => (
              <li>
                <span class="exp__branch" aria-hidden="true">{j === e.roles.length - 1 ? "└─" : "├─"}</span>
                <div class="exp__role">
                  <strong>{r.title}</strong><span class="exp__rp"> · {pick(r.period, locale)}</span>
                  <p>{pick(r.summary, locale)}</p>
                  <p class="exp__tags">{r.tags.map((tag) => <span class="exp__tag">{tag}</span>)}</p>
                </div>
              </li>
            ))}
          </ol>
        </details>
      </li>
    ))}
    {rest.length > 0 && (
      <li class="exp__moreli">
        <span class="exp__node" aria-hidden="true">┄</span>
        <button class="exp__more" type="button">[+] {moreLabel}</button>
      </li>
    )}
  </ol>
</section>
<script>
  import { mountAsciiMark } from "../lib/ascii/mark";

  const more = document.querySelector<HTMLButtonElement>(".exp__more");
  more?.addEventListener("click", () => {
    document.querySelectorAll(".exp__entry[hidden]").forEach((el) => el.removeAttribute("hidden"));
    more.closest(".exp__moreli")?.remove();
  });

  // living marks: same physics as the hero face (skip under reduced motion)
  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    document.querySelectorAll<HTMLElement>(".exp__entry").forEach((entry) => {
      const pre = entry.querySelector<HTMLPreElement>("pre.exp__mark");
      const details = entry.querySelector<HTMLDetailsElement>("details");
      if (!pre || !details) return;
      const mark = mountAsciiMark(pre);
      if (!mark) return;
      const update = () => mark.setAccent(entry.matches(":hover") || details.open);
      entry.addEventListener("mouseenter", update);
      entry.addEventListener("mouseleave", update);
      details.addEventListener("toggle", update);
    });
  }
</script>
<style>
  .exp { padding-block: var(--space-8); }
  .exp__head { display: flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-4); }
  .exp__head h2 { flex: 1; }
  .exp__info { position: relative; cursor: help; color: var(--accent); display: inline-flex; }
  .exp__info:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
  .exp__tip {
    position: absolute; top: 130%; right: 0; width: min(320px, 80vw); z-index: 5;
    background: #000; border: 1px solid var(--fg-dim); color: var(--fg);
    padding: var(--space-2); font-size: var(--fs-sm); line-height: 1.5;
    opacity: 0; visibility: hidden; transition: opacity .12s;
  }
  .exp__info:hover .exp__tip, .exp__info:focus .exp__tip, .exp__info:focus-within .exp__tip { opacity: 1; visibility: visible; }

  /* the spine: career as a commit log */
  .exp__log { list-style: none; margin: 0; padding: 0; position: relative; }
  .exp__log::before {
    content: ""; position: absolute; top: 6px; bottom: 6px; left: 7px;
    border-left: 1px dashed var(--fg-dim); opacity: .5;
  }
  .exp__entry, .exp__moreli { position: relative; padding-left: var(--space-4); list-style: none; }
  .exp__entry + .exp__entry, .exp__moreli { margin-top: var(--space-3); }
  .exp__node {
    position: absolute; left: 0; top: 14px; width: 15px; text-align: center;
    color: var(--fg-dim); background: var(--bg); line-height: 1;
    transition: color .25s, text-shadow .25s;
  }
  .exp__entry:first-child .exp__node { color: var(--accent); }

  .exp__item summary {
    cursor: pointer; list-style: none;
    display: grid; grid-template-columns: minmax(140px, 230px) 1fr; gap: var(--space-3);
    align-items: center; padding: var(--space-2);
    border: 1px solid color-mix(in srgb, var(--fg-dim) 35%, transparent);
    transition: border-color .25s, background .25s;
  }
  .exp__item summary::-webkit-details-marker { display: none; }
  .exp__item summary:hover, .exp__item[open] summary {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 4%, transparent);
  }
  .exp__item summary:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }

  /* marks scale to their box — they never scroll */
  .exp__markbox { display: block; container-type: inline-size; min-width: 0; }
  .exp__mark {
    margin: 0; white-space: pre; overflow: hidden; text-align: center;
    font-size: min(11px, calc(100cqw / (var(--cols) * 0.6001)));
    line-height: 1.1; color: var(--fg-dim);
    transition: color .3s, filter .3s;
  }
  /* a slow scanning glint sweeps each mark, out of phase per entry */
  @media (prefers-reduced-motion: no-preference) {
    .exp__mark {
      background: linear-gradient(105deg, #666 0% 35%, #fff 47%, #ffb37a 50%, #fff 53%, #666 65% 100%) 0 0 / 240% 100%;
      -webkit-background-clip: text; background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: exp-scan 5s linear infinite;
      animation-delay: calc(var(--i, 0) * -1.3s);
    }
    @keyframes exp-scan { to { background-position: -240% 0; } }
  }
  /* ignite on hover / open */
  .exp__entry:hover .exp__mark, .exp__item[open] .exp__mark {
    color: var(--accent);
    -webkit-text-fill-color: var(--accent);
    animation: none;
    filter: drop-shadow(0 0 9px color-mix(in srgb, var(--accent) 55%, transparent));
  }
  .exp__entry:hover .exp__node, .exp__item[open] .exp__node {
    color: var(--accent);
    text-shadow: 0 0 10px color-mix(in srgb, var(--accent) 60%, transparent);
  }

  .exp__meta { display: grid; gap: 2px; min-width: 0; }
  .exp__co { font-size: var(--fs-lg); }
  .exp__period { color: var(--fg-dim); font-size: var(--fs-sm); }
  .exp__lead { color: var(--fg-dim); }
  .exp__toggle { color: var(--accent); font-size: var(--fs-sm); margin-top: 4px; }
  .exp__sign::before { content: "[+] "; }
  .exp__item[open] .exp__sign::before { content: "[−] "; }

  .exp__roles {
    list-style: none; margin: 0; padding: var(--space-3) var(--space-2);
    display: grid; gap: var(--space-3);
    border: 1px solid color-mix(in srgb, var(--fg-dim) 35%, transparent); border-top: 0;
  }
  @media (prefers-reduced-motion: no-preference) {
    .exp__item[open] .exp__roles { animation: roles-in .35s ease both; }
    @keyframes roles-in { from { opacity: 0; transform: translateY(-6px); } }
  }
  .exp__roles > li { display: grid; grid-template-columns: auto 1fr; gap: var(--space-2); }
  .exp__branch { color: var(--fg-dim); user-select: none; }
  .exp__role p { margin-top: 4px; max-width: 72ch; }
  .exp__rp { color: var(--fg-dim); }
  .exp__tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .exp__tag { color: var(--fg-dim); font-size: var(--fs-sm); }
  .exp__tag::before { content: "["; }
  .exp__tag::after { content: "]"; }

  /* the "show more" gate sits on the spine like one more entry */
  .exp__moreli .exp__node { top: 50%; translate: 0 -50%; }
  .exp__more {
    font: inherit; width: 100%; cursor: pointer; text-align: center;
    color: var(--accent); background: none;
    border: 1px dashed color-mix(in srgb, var(--fg-dim) 55%, transparent);
    padding: var(--space-2) var(--space-3);
    transition: border-color .2s, background .2s;
  }
  .exp__more:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 6%, transparent);
  }
  .exp__more:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }

  @media (max-width: 560px) {
    .exp__item summary { grid-template-columns: 1fr; justify-items: center; text-align: center; }
    .exp__markbox { width: min(60vw, 220px); }
    .exp__meta { justify-items: center; }
    .exp__log::before { display: none; }
    .exp__node { display: none; }
    .exp__entry, .exp__moreli { padding-left: 0; }
  }
</style>
