---
import "../styles/global.css";
import AsciiBackground from "../components/AsciiBackground.astro";
import { useT, type Locale } from "../i18n/ui";

const locale = (Astro.currentLocale ?? "en") as Locale;
const t = useT(locale);
const site = Astro.site!;
const enUrl = new URL("/", site).href;
const esUrl = new URL("/es/", site).href;
const canonical = locale === "es" ? esUrl : enUrl;
const ogImage = new URL("/og.png", site).href;
const title = t("meta.title");
const description = t("meta.description");

const person = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Richard Lozada",
  url: enUrl,
  jobTitle: "Technical Lead — Frontend",
  worksFor: { "@type": "Organization", name: "Openbank (Grupo Santander)" },
  sameAs: ["https://github.com/Lozadaa", "https://www.linkedin.com/in/richardlozada/", "https://x.com/Lozadapp"],
  email: "mailto:hi@richardlozada.com",
  knowsAbout: ["React", "Next.js", "Angular", "TypeScript", "Ruby on Rails", "Java", "Node.js", "AWS"],
};
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#000000" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Richard Lozada" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={locale === "es" ? "es_ES" : "en_US"} />
    <meta property="og:locale:alternate" content={locale === "es" ? "en_US" : "es_ES"} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(person)} />
    <script is:inline>
      // language routing: explicit choice wins; otherwise follow the browser once
      (function () {
        try {
          var pref = localStorage.getItem("lang");
          var isEs = location.pathname === "/es" || location.pathname.indexOf("/es/") === 0;
          if (pref === "es" && !isEs) location.replace("/es/");
          else if (pref === "en" && isEs) location.replace("/");
          else if (!pref && !isEs && (navigator.language || "").toLowerCase().indexOf("es") === 0) location.replace("/es/");
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">{t("skip")}</a>
    <nav class="lang" aria-label={t("lang.label")}>
      <a href="/" aria-current={locale === "en" ? "page" : undefined} onclick="try{localStorage.setItem('lang','en')}catch(e){}">EN</a>
      <span aria-hidden="true">/</span>
      <a href="/es/" aria-current={locale === "es" ? "page" : undefined} onclick="try{localStorage.setItem('lang','es')}catch(e){}">ES</a>
    </nav>
    <AsciiBackground />
    <main id="main"><slot /></main>
    <script>
      const els = document.querySelectorAll("[data-reveal]");
      if ("IntersectionObserver" in window) {
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) if (e.isIntersecting) { e.target.classList.add("is-in"); io.unobserve(e.target); }
        }, { rootMargin: "0px 0px -8% 0px" });
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add("is-in"));
      }
    </script>
  </body>
</html>
<style>
  .lang {
    position: absolute; top: var(--space-3); right: var(--space-4); z-index: 3;
    display: flex; gap: var(--space-1); color: var(--fg-dim); font-size: var(--fs-sm);
  }
  .lang a { color: var(--fg-dim); }
  .lang a[aria-current="page"] { color: var(--accent); }
  .lang a:hover { color: var(--fg); text-decoration: none; }
</style>
