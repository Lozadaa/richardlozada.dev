---
interface Props { slug: string; label: string }
const { slug, label } = Astro.props;
---
<canvas class="ascii-project" data-slug={slug} role="img" aria-label={label}></canvas>
<script>
  import { mountAscii } from "../../lib/ascii/renderer";
  import { projectsData } from "../../lib/ascii/projects-data";
  document.querySelectorAll<HTMLCanvasElement>("canvas.ascii-project").forEach((el) => {
    const slug = el.dataset.slug;
    const data = slug ? projectsData[slug] : undefined;
    // `wave` = cheap ambient ripple over a pre-rendered static buffer, so high detail
    // costs nothing per frame and every thumbnail can drift at once. ambient:false keeps
    // the physics field idle (it only drives the push on hover). fps caps the ripple.
    if (data) mountAscii(el, data, { wave: true, fps: 30, ambient: false });
    else el.remove();
  });
</script>
<style>
  /* Fixed 16:9 banner. object-fit:cover scales the canvas uniformly (never stretched)
     and object-position:center crops overflow from the edges — "show the center,
     crop what doesn't fit". */
  .ascii-project {
    display: block; width: 100%; aspect-ratio: 16 / 9;
    object-fit: cover; object-position: center;
    image-rendering: pixelated; background: #000; border: 1px solid var(--fg-dim);
  }
  @media (pointer: coarse) { .ascii-project { cursor: default; } }
</style>
