---
import { aboutParagraphs } from "../content/about";
---
<section class="container about" aria-labelledby="about-h">
  <h2 id="about-h">About</h2>
  <div class="about__body">{aboutParagraphs.map((p) => <p>{p}</p>)}</div>
</section>
<style>
  .about { padding-block: var(--space-8); }
  .about__body {
    margin-top: var(--space-3);
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }
  .about__body p { max-width: var(--measure); }
  @media (min-width: 900px) {
    .about__body { grid-template-columns: repeat(3, 1fr); }
    .about__body p { max-width: none; }
  }
</style>
