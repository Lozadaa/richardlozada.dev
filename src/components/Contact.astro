---
import AsciiLink from "./ascii/AsciiLink.astro";
import site from "../content/site.json";
import { useT, type Locale } from "../i18n/ui";
const locale = (Astro.currentLocale ?? "en") as Locale;
const t = useT(locale);
const year = new Date().getFullYear();
---
<footer class="container contact" aria-labelledby="contact-h">
  <h2 id="contact-h">{t("contact.heading")}</h2>
  <nav class="contact__links" aria-label={t("contact.links")}>
    {site.contacts.map((c) => <AsciiLink href={c.href} label={c.label} />)}
  </nav>
  <p class="contact__sig">{t("footer.sig")} · {year}</p>
</footer>
<style>
  .contact { padding-block: var(--space-8); text-align: center; }
  .contact__links {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    justify-content: center;
    margin-top: var(--space-3);
  }
  .contact__sig { color: var(--fg-dim); margin-top: var(--space-4); }
</style>
