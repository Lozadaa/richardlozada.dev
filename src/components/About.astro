---
import { aboutParagraphs, certifications, press } from "../content/about";
import { useT, type Locale } from "../i18n/ui";
const locale = (Astro.currentLocale ?? "en") as Locale;
const t = useT(locale);
---
<section class="container about" aria-labelledby="about-h">
  <h2 id="about-h">{t("about.heading")}</h2>
  <div class="about__body" data-reveal>{aboutParagraphs[locale].map((p) => <p>{p}</p>)}</div>
  <div class="about__certs" data-reveal>
    <h3 class="about__certs-h">{t("about.press")}</h3>
    <ul class="about__cert-list">
      {press.map((p) => (
        <li>
          <a class="about__cert" href={p.href} target="_blank" rel="noopener" title={`Abastece Combustible (2015) — ${p.name}`}>
            <span class="about__bracket" aria-hidden="true">[ </span>{p.name} <span class="about__issuer">↗</span><span class="about__bracket" aria-hidden="true"> ]</span>
          </a>
        </li>
      ))}
    </ul>
    <h3 class="about__certs-h about__certs-h--second">{t("about.certs")}</h3>
    <ul class="about__cert-list">
      {certifications.map((c) => (
        <li>
          <a class="about__cert" href={c.href} target="_blank" rel="noopener" title={`${c.name} — ${c.issuer}`}>
            <span class="about__bracket" aria-hidden="true">[ </span>{c.name} <span class="about__issuer">· {c.issuer} ↗</span><span class="about__bracket" aria-hidden="true"> ]</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
<style>
  .about { padding-block: var(--space-8); }
  .about__body {
    margin-top: var(--space-3);
    display: grid;
    gap: var(--space-3);
  }
  .about__body p { max-width: none; font-size: var(--fs-lg); }
  .about__certs { margin-top: var(--space-4); }
  .about__certs-h { font-size: var(--fs-base); color: var(--fg-dim); font-weight: 400; letter-spacing: 0.08em; text-transform: uppercase; }
  .about__certs-h--second { margin-top: var(--space-3); }
  .about__cert-list {
    list-style: none; margin: var(--space-2) 0 0; padding: 0;
    display: flex; flex-wrap: wrap; gap: var(--space-1) var(--space-3);
  }
  .about__cert { color: var(--fg); }
  .about__cert:hover { color: var(--accent); text-decoration: none; }
  .about__bracket { color: var(--accent); }
  .about__issuer { color: var(--fg-dim); font-size: var(--fs-sm); }
  .about__cert:hover .about__issuer { color: var(--accent); }
</style>
