---
---
<canvas class="ascii-bg" aria-hidden="true"></canvas>
<script>
  // Each glyph drifts sideways (dx: the star of the motion) with a gentle vertical
  // sway (sine of phase/freq/amp) so the field feels alive without a rigid scroll.
  interface G { x: number; y: number; vx: number; vy: number; dx: number; ch: string; a: number; phase: number; freq: number; amp: number }
  const cv = document.querySelector<HTMLCanvasElement>(".ascii-bg");
  if (cv) {
    const ctx = cv.getContext("2d")!;
    const SYMS = "01<>/\\{}[]()=+*#.:~^|".split("");
    let W = 0, H = 0, glyphs: G[] = [], t = 0;
    let mx = -9999, my = -9999;
    function build() {
      W = cv!.width = window.innerWidth;
      H = cv!.height = window.innerHeight;
      const count = Math.min(240, Math.floor((W * H) / 9000));
      glyphs = Array.from({ length: count }, (): G => ({
        x: Math.random() * W, y: Math.random() * H, vx: 0, vy: 0,
        // sideways drift: mixed direction, varied speed → a slow horizontal current
        dx: (Math.random() < 0.5 ? -1 : 1) * (0.14 + Math.random() * 0.26),
        ch: SYMS[Math.floor(Math.random() * SYMS.length)],
        a: 0.03 + Math.random() * 0.05,
        phase: Math.random() * Math.PI * 2,
        freq: 0.008 + Math.random() * 0.016,
        amp: 0.1 + Math.random() * 0.2,
      }));
    }
    function paint(move: boolean) {
      ctx.clearRect(0, 0, W, H);
      ctx.font = "13px monospace"; ctx.textBaseline = "top";
      const R = 120;
      if (move) t += 1;
      for (const g of glyphs) {
        if (move) {
          // pointer repel — glyphs push away when the cursor passes near
          const ddx = g.x - mx, ddy = g.y - my, d = Math.hypot(ddx, ddy);
          if (d < R && d > 0.01) { const f = (1 - d / R) * 0.5; g.vx += (ddx / d) * f; g.vy += (ddy / d) * f; }
          g.vx *= 0.92; g.vy *= 0.92;
          const sway = Math.sin(t * g.freq + g.phase) * g.amp;
          g.x += g.vx + g.dx; g.y += g.vy + sway;
          if (g.x < -10) g.x = W + 10; if (g.x > W + 10) g.x = -10;
          if (g.y < -10) g.y = H + 10; if (g.y > H + 10) g.y = -10;
        }
        ctx.fillStyle = `rgba(230,230,230,${g.a})`;
        ctx.fillText(g.ch, g.x, g.y);
      }
    }
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    build();
    window.addEventListener("resize", () => { build(); paint(false); });
    if (reduce) {
      paint(false);
    } else {
      let raf = 0, running = false;
      const loop = () => { paint(true); raf = requestAnimationFrame(loop); };
      const start = () => { if (!running && !document.hidden) { running = true; loop(); } };
      const stop = () => { running = false; cancelAnimationFrame(raf); };
      window.addEventListener("pointermove", (e) => { mx = e.clientX; my = e.clientY; });
      document.addEventListener("visibilitychange", () => (document.hidden ? stop() : start()));
      start();
    }
  }
</script>
<style>
  .ascii-bg { position: fixed; inset: 0; width: 100vw; height: 100vh; z-index: 0; pointer-events: none; }
</style>
